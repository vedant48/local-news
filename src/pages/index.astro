---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/article/ArticleCard.astro';
import { blogAPI } from '../utils/api';

const posts = await blogAPI.getAll(1, 20);
const featuredPost = posts[0];
const secondaryPosts = posts.slice(1, 4);
const recentPosts = posts.slice(4, 13);
---

<BaseLayout title="Home" description="Latest local news and updates from your community">
  <div class="container mx-auto px-4 py-8">

    <!-- Featured + Secondary layout -->
    {featuredPost && (
      <section class="mb-12">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
          <!-- Main featured post -->
          <div class="lg:col-span-2">
            <ArticleCard post={featuredPost} variant="featured" />
          </div>
          <!-- Secondary posts sidebar -->
          {secondaryPosts.length > 0 && (
            <div class="flex flex-col gap-4">
              <h2 class="text-xs font-bold uppercase tracking-widest text-red-600 dark:text-red-400 border-b-2 border-red-600 pb-2">
                Top Stories
              </h2>
              {secondaryPosts.map(post => (
                <ArticleCard post={post} variant="compact" />
              ))}
            </div>
          )}
        </div>
      </section>
    )}

    <!-- Section divider -->
    <div class="flex items-center gap-4 mb-8">
      <h2 class="text-xs font-bold uppercase tracking-widest text-red-600 dark:text-red-400 whitespace-nowrap border-b-2 border-red-600 pb-2">
        Latest News
      </h2>
      <div class="flex-1 border-b border-gray-200 dark:border-gray-700"></div>
    </div>

    <!-- Recent Posts Grid -->
    {recentPosts.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {recentPosts.map(post => (
          <ArticleCard post={post} />
        ))}
      </div>
    ) : (
      <div class="text-center py-16 text-gray-500 dark:text-gray-400">
        <svg class="w-12 h-12 mx-auto mb-4 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
        </svg>
        <p class="text-lg">No articles available yet.</p>
      </div>
    )}
  </div>
</BaseLayout>