---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/article/ArticleCard.astro';
import { blogAPI } from '../../utils/api';

const { tag } = Astro.params;
const displayTag = tag || 'Tag';
const posts = await blogAPI.getByTag(displayTag, 1);
---

<BaseLayout title={`#${displayTag}`} description={`Articles tagged with ${displayTag}`}>
  <div class="container mx-auto px-4 py-8">
    <div class="mb-8 pb-4 border-b-2 border-red-600">
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-gray-100">
        <span class="text-red-600 dark:text-red-400">#</span>{displayTag}
      </h1>
      <p class="text-gray-500 dark:text-gray-400 mt-2">
        {posts.length > 0 ? `${posts.length} article${posts.length !== 1 ? 's' : ''} found` : 'No articles found'}
      </p>
    </div>

    {posts.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {posts.map(post => (
          <ArticleCard post={post} />
        ))}
      </div>
    ) : (
      <div class="text-center py-16 text-gray-500 dark:text-gray-400">
        <p class="text-lg mb-2">No articles with this tag yet.</p>
        <a href="/" class="text-red-600 dark:text-red-400 hover:underline">Back to Home</a>
      </div>
    )}
  </div>
</BaseLayout>