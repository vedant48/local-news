---
import type { BlogPost } from '../../types/blog';
import { formatDate } from '../../utils/date';

interface Props {
  post: BlogPost;
  variant?: 'default' | 'featured' | 'compact';
}

const { post, variant = 'default' } = Astro.props;
---

{variant === 'featured' && (
  <article class="group relative overflow-hidden rounded-lg shadow-lg bg-white dark:bg-gray-800">
    <div class="aspect-w-16 aspect-h-9">
      <img 
        src={post.coverImageUrl} 
        alt={post.title}
        class="object-cover w-full h-64 group-hover:scale-105 transition-transform duration-300"
      />
    </div>
    <div class="p-6">
      <div class="flex items-center space-x-2 text-sm text-gray-500 mb-3">
        <span class="text-red-600 font-semibold">{post.category}</span>
        <span>•</span>
        <time datetime={post.createdAt}>{formatDate(post.createdAt)}</time>
        <span>•</span>
        <span>{post.readingTimeMinutes} min read</span>
      </div>
      <h2 class="text-2xl font-bold mb-3 hover:text-red-600 transition">
        <a href={`/blogs/${post.id}`}>{post.title}</a>
      </h2>
      <p class="text-gray-600 dark:text-gray-300 mb-4">{post.excerpt}</p>
      {post.location && (
        <div class="flex items-center gap-1 text-sm text-gray-500">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          <span>{post.location}</span>
        </div>
      )}
    </div>
  </article>
)}

{variant === 'default' && (
  <article class="bg-white dark:bg-gray-800 rounded-lg shadow-md overflow-hidden hover:shadow-lg transition">
    <div class="flex flex-col md:flex-row">
      <img 
        src={post.coverImageUrl} 
        alt={post.title}
        class="w-full md:w-48 h-48 object-cover"
      />
      <div class="p-5 flex-1">
        <div class="flex items-center space-x-2 text-sm text-gray-500 mb-2 flex-wrap gap-y-2">
          <span class="text-red-600 font-semibold">{post.category}</span>
          <span>•</span>
          <time datetime={post.createdAt}>{formatDate(post.createdAt)}</time>
          <span>•</span>
          <span>{post.readingTimeMinutes} min read</span>
          {post.location && (
            <>
              <span>•</span>
              <span>📍 {post.location}</span>
            </>
          )}
        </div>
        <h3 class="text-xl font-semibold mb-2 hover:text-red-600 transition">
          <a href={`/blogs/${post.id}`}>{post.title}</a>
        </h3>
        <p class="text-gray-600 dark:text-gray-300 text-sm mb-3">{post.excerpt}</p>
        <div class="flex flex-wrap gap-2">
          {post.tags.slice(0, 3).map(tag => (
            <a href={`/tags/${tag}`} class="text-xs bg-gray-100 dark:bg-gray-700 px-2 py-1 rounded hover:bg-gray-200">
              #{tag}
            </a>
          ))}
        </div>
      </div>
    </div>
  </article>
)}