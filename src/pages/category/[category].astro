---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/article/ArticleCard.astro';
import { blogAPI } from '../../utils/api';

const { category } = Astro.params;
const displayCategory = category ? category.charAt(0).toUpperCase() + category.slice(1) : 'Category';
const posts = await blogAPI.getByCategory(category || '', 1);
---

<BaseLayout title={displayCategory} description={`Latest ${displayCategory} news`}>
  <div class="container mx-auto px-4 py-8">
    <div class="mb-8 pb-4 border-b-2 border-red-600">
      <div class="flex items-center gap-3 mb-2">
        <span class="bg-red-600 text-white text-xs px-2 py-1 rounded font-bold uppercase tracking-widest">
          {displayCategory}
        </span>
      </div>
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-gray-100">
        {displayCategory} News
      </h1>
      <p class="text-gray-500 dark:text-gray-400 mt-2">
        {posts.length > 0 ? `${posts.length} article${posts.length !== 1 ? 's' : ''} found` : 'No articles found'}
      </p>
    </div>

    {posts.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {posts.map(post => (
          <ArticleCard post={post} />
        ))}
      </div>
    ) : (
      <div class="text-center py-16 text-gray-500 dark:text-gray-400">
        <svg class="w-12 h-12 mx-auto mb-4 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
        </svg>
        <p class="text-lg mb-2">No articles in this category yet.</p>
        <a href="/" class="text-red-600 dark:text-red-400 hover:underline">Back to Home</a>
      </div>
    )}
  </div>
</BaseLayout>